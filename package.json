    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hotkeys-js": "^4.0.2",
    "idb": "^8.0.3",
    "klona": "^2.0.6",
    "lucide-vue-next": "^0.577.0",
    "nanoid": "^5.1.6",
    "patch-package": "^8.0.1",
    "reka-ui": "^2.9.0",
    "smart-invariant": "^2.0.0",
    "sortablejs": "^1.15.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tinykeys": "^3.0.0",
    "tw-animate-css": "^1.4.0",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3",
